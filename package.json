{
  "name": "gt-arcade",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Gas Town Arcade — Gather Town-style gamified pixel art dashboard for Gas Town",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3200",
